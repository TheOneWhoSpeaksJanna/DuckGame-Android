<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>DGSteam</AssemblyName>
    <RootNamespace>Steam</RootNamespace>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoWarn>SYSLIB0003;SYSLIB0032;CS0436</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="src/**/*.cs" />
    <Compile Include="Properties/AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Real Steamworks.NET implementation assembly (valid managed IL). Steam is
         non-functional on Android (no native steam_api), but referencing the actual
         managed assembly lets DGSteam.dll compile and load; all Steam calls are
         guarded by Steam.IsInitialized which is false on Android. -->
    <Reference Include="Steamworks.NET">
      <HintPath>..\lib\Steamworks.NET.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
